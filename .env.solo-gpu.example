# Required: rewards will go to the wallet behind this private key
PRIVATE_KEY=0xreplace_with_your_wallet_private_key

# Recommended: stable mainnet RPC
RPC_URL=https://ethereum-rpc.publicnode.com

# Usually you can leave the rest untouched on a single Ubuntu GPU server
MASTER_PORT=7331
MIN_GAS_BALANCE=0.001
AGENT_NAME=gpu-4090
GPU_PLATFORM=0
GPU_DEVICE=0
GPU_GLOBAL_WORK_SIZE=4194304
GPU_LOCAL_WORK_SIZE=256
GPU_PROGRESS_MS=1000

# Optional overrides
# MASTER_TOKEN=
# GPU_EXECUTABLE=gpu-miner/build/hash256-gpu-miner
# GPU_KERNEL_PATH=gpu-miner/build/kernels/keccak_miner.cl
